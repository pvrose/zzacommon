# zzacommonConfig.cmake
# CMake package configuration file for ZZACOMMON library
#
# Usage:
#   find_package(zzacommon REQUIRED COMPONENTS zzaf zzab zzax zzam)
#
# Components:
#   zzaf - FLTK UI components (requires FLTK)
#   zzab - Boost components (requires Boost filesystem, asio)
#   zzax - XML, URL handling, and FLTK (requires pugixml, libcurl, zlib, FLTK)
#   zzam - Common utilities (requires nlohmann/json)
#   zzafb - FLTK + Boost components (requires FLTK, Boost, nlohmann/json)
#   zzad - Debug utilities (no external dependencies)
#   zzap - PortAudio audio output (requires PortAudio, zzam)
#
# Variables set by this module:
#   zzacommon_FOUND          - True if zzacommon is found
#   zzacommon_VERSION        - Version of zzacommon
#   ZZACOMMON_INCLUDE_DIR    - Include directory for zzacommon
#   ZZACOMMON_LIBRARIES      - List of component libraries found
#   ZZACOMMON_COMPONENTS     - List of components found
#   FLTK_INCLUDE_DIR         - FLTK include directory (if zzaf or zzax used)
#
# Imported targets:
#   zzacommon::zzaf          - FLTK UI components target
#   zzacommon::zzab          - Boost components target
#   zzacommon::zzax          - XML, URL, and FLTK target
#   zzacommon::zzam          - Common utilities target
#   zzacommon::zzafb         - FLTK + Boost target
#   zzacommon::zzad          - Debug utilities target
#   zzacommon::zzap          - PortAudio audio output target

@PACKAGE_INIT@

# Include runtime helper functions
include("${CMAKE_CURRENT_LIST_DIR}/zzacommon_runtime_helpers.cmake")

# Diagnostic message indicating find_package usage
message(STATUS "zzacommon: Loaded via find_package (version @ZZACOMMON_VERSION@)")

# Set version information
set(zzacommon_VERSION "@ZZACOMMON_VERSION@")
set(ZZACOMMON_VERSION "@ZZACOMMON_VERSION@")

# Set include directory using PACKAGE_PREFIX_DIR (set by @PACKAGE_INIT@)
set_and_check(ZZACOMMON_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/include")

# CMake helper scripts (set by configure_package_config_file)
set_and_check(ZZACOMMON_CMAKE_DIR "@PACKAGE_ZZACOMMON_CMAKE_DIR@")

# API documentation directory (if installed)
set(ZZACOMMON_API_HTML_DIR "${PACKAGE_PREFIX_DIR}/share/doc/zzacommon/html")
if(EXISTS "${ZZACOMMON_API_HTML_DIR}")
    message(STATUS "zzacommon: API documentation available at ${ZZACOMMON_API_HTML_DIR}")
else()
    set(ZZACOMMON_API_HTML_DIR "")
endif()

# Propagate vcpkg paths for finding dependencies (if VCPKG_ROOT was used during build)
set(_ZZACOMMON_VCPKG_ROOT "@VCPKG_ROOT@")
if(_ZZACOMMON_VCPKG_ROOT AND EXISTS "${_ZZACOMMON_VCPKG_ROOT}")
    # Add vcpkg paths to CMAKE_PREFIX_PATH if not already present
    list(APPEND CMAKE_PREFIX_PATH "${_ZZACOMMON_VCPKG_ROOT}/installed/x64-windows")
    list(APPEND CMAKE_PREFIX_PATH "${_ZZACOMMON_VCPKG_ROOT}/installed/x64-windows/share")
    message(STATUS "zzacommon: Using vcpkg from ${_ZZACOMMON_VCPKG_ROOT}")
elseif(DEFINED ENV{VCPKG_ROOT} AND EXISTS "$ENV{VCPKG_ROOT}")
    # Fallback to environment variable if available
    list(APPEND CMAKE_PREFIX_PATH "$ENV{VCPKG_ROOT}/installed/x64-windows")
    list(APPEND CMAKE_PREFIX_PATH "$ENV{VCPKG_ROOT}/installed/x64-windows/share")
    message(STATUS "zzacommon: Using vcpkg from environment: $ENV{VCPKG_ROOT}")
endif()

# Available components
set(ZZACOMMON_AVAILABLE_COMPONENTS zzaf zzab zzax zzam zzafb zzad zzap)

# If no components specified, use all
if(NOT zzacommon_FIND_COMPONENTS)
    set(zzacommon_FIND_COMPONENTS ${ZZACOMMON_AVAILABLE_COMPONENTS})
endif()

# Check that requested components are valid
foreach(comp ${zzacommon_FIND_COMPONENTS})
    if(NOT comp IN_LIST ZZACOMMON_AVAILABLE_COMPONENTS)
        set(zzacommon_FOUND False)
        set(zzacommon_NOT_FOUND_MESSAGE "Unsupported component: ${comp}")
        return()
    endif()
endforeach()

# Initialize component found flags
set(ZZACOMMON_COMPONENTS "")
set(ZZACOMMON_LIBRARIES "")

# Check which components are requested
list(FIND zzacommon_FIND_COMPONENTS "zzaf" ZZAF_REQUESTED)
list(FIND zzacommon_FIND_COMPONENTS "zzab" ZZAB_REQUESTED)
list(FIND zzacommon_FIND_COMPONENTS "zzax" ZZAX_REQUESTED)
list(FIND zzacommon_FIND_COMPONENTS "zzam" ZZAM_REQUESTED)
list(FIND zzacommon_FIND_COMPONENTS "zzafb" ZZAFB_REQUESTED)
list(FIND zzacommon_FIND_COMPONENTS "zzad" ZZAD_REQUESTED)
list(FIND zzacommon_FIND_COMPONENTS "zzap" ZZAP_REQUESTED)

# Find dependencies for requested components

# FLTK is required by zzaf, zzax, and zzafb
if(NOT ZZAF_REQUESTED EQUAL -1 OR NOT ZZAX_REQUESTED EQUAL -1 OR NOT ZZAFB_REQUESTED EQUAL -1)
    # MSVC work-round as FLTK built in user space
    if(MSVC AND NOT FLTK_DIR)
        message(WARNING "FLTK_DIR not set. You may need to set it for zzaf/zzax/zzafb components.")
    endif()

    find_package(FLTK CONFIG QUIET)
    if(NOT FLTK_FOUND)
        if(zzacommon_FIND_REQUIRED)
            message(FATAL_ERROR "FLTK is required for zzaf/zzax/zzafb components but was not found")
        else()
            message(WARNING "FLTK not found - zzaf/zzax/zzafb components will not be available")
        endif()
    else()
        set(FLTK_INCLUDE_DIR ${FLTK_INCLUDE_DIR})
    endif()
endif()

# Boost is required by zzab and zzafb
if(NOT ZZAB_REQUESTED EQUAL -1 OR NOT ZZAFB_REQUESTED EQUAL -1)
    # Use non-QUIET mode if component is required so user sees helpful error messages
    if(zzacommon_FIND_REQUIRED_zzab OR zzacommon_FIND_REQUIRED_zzafb)
        set(_BOOST_FIND_MODE REQUIRED)
    else()
        set(_BOOST_FIND_MODE QUIET)
    endif()

    if(MSVC)
        find_package(Boost 1.85.0 CONFIG ${_BOOST_FIND_MODE} COMPONENTS filesystem asio)
    else()
        find_package(Boost 1.83.0 CONFIG ${_BOOST_FIND_MODE} COMPONENTS filesystem)
    endif()

    if(NOT Boost_FOUND)
        if(zzacommon_FIND_REQUIRED_zzab OR zzacommon_FIND_REQUIRED_zzafb)
            message(FATAL_ERROR "Boost is required for zzab/zzafb component but was not found.\n"
                "To resolve this:\n"
                "  1. Install via vcpkg: vcpkg install boost-filesystem:x64-windows boost-asio:x64-windows\n"
                "  2. Set VCPKG_ROOT environment variable or CMake variable\n"
                "  3. Or add Boost installation to CMAKE_PREFIX_PATH\n"
                "  4. Or set Boost_DIR to point to BoostConfig.cmake location")
        else()
            message(WARNING "Boost not found - zzab/zzafb component will not be available")
        endif()
    endif()
endif()

# pugixml, libcurl, and zlib are required by zzax
if(NOT ZZAX_REQUESTED EQUAL -1)
    # Find pugixml - use find_package for vcpkg compatibility
    find_package(pugixml CONFIG QUIET)

    if(NOT pugixml_FOUND AND NOT TARGET pugixml)
        # Fallback: Try to find in zzacommon install tree (if pugixml was built as part of zzacommon)
        find_path(PUGIXML_INCLUDE_DIR pugixml.hpp
            PATHS "${PACKAGE_PREFIX_DIR}/include/pugixml"
            NO_DEFAULT_PATH)

        if(PUGIXML_INCLUDE_DIR AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/pugixml${CMAKE_STATIC_LIBRARY_SUFFIX}")
            add_library(pugixml STATIC IMPORTED)
            set(PUGIXML_LIB "${PACKAGE_PREFIX_DIR}/lib/pugixml${CMAKE_STATIC_LIBRARY_SUFFIX}")
            set_target_properties(pugixml PROPERTIES
                IMPORTED_LOCATION "${PUGIXML_LIB}"
                INTERFACE_INCLUDE_DIRECTORIES "${PUGIXML_INCLUDE_DIR}"
            )
            message(STATUS "zzacommon: Using bundled pugixml from install tree")
        else()
            if(zzacommon_FIND_REQUIRED_zzax)
                message(FATAL_ERROR "pugixml is required for zzax component but was not found.\n"
                    "To resolve this:\n"
                    "  1. Install via vcpkg: vcpkg install pugixml:x64-windows\n"
                    "  2. Set VCPKG_ROOT environment variable\n"
                    "  3. Or add pugixml installation to CMAKE_PREFIX_PATH")
            else()
                message(WARNING "pugixml not found - zzax component will not be available")
            endif()
        endif()
    endif()

    # Find CURL
    if(MSVC)
        find_package(CURL CONFIG QUIET)
    else()
        find_package(CURL QUIET)
    endif()

    if(NOT CURL_FOUND)
        if(zzacommon_FIND_REQUIRED_zzax)
            message(FATAL_ERROR "CURL is required for zzax component but was not found.\n"
                "To resolve this:\n"
                "  1. Install via vcpkg: vcpkg install curl:x64-windows\n"
                "  2. Set VCPKG_ROOT environment variable\n"
                "  3. Or add CURL installation to CMAKE_PREFIX_PATH")
        else()
            message(WARNING "CURL not found - zzax component will not be available")
        endif()
    endif()

    # Find ZLIB on Windows only
    if(MSVC)
        find_package(ZLIB CONFIG QUIET)
        if(NOT ZLIB_FOUND)
            find_package(ZLIB MODULE QUIET)
        endif()

        if(NOT ZLIB_FOUND)
            if(zzacommon_FIND_REQUIRED_zzax)
                message(FATAL_ERROR "ZLIB is required for zzax component on Windows but was not found.\n"
                    "To resolve this:\n"
                    "  1. Install via vcpkg: vcpkg install zlib:x64-windows\n"
                    "  2. Set VCPKG_ROOT environment variable\n"
                    "  3. Or add ZLIB installation to CMAKE_PREFIX_PATH")
            else()
                message(WARNING "ZLIB not found on Windows - zzax component may not be fully available")
            endif()
        endif()
    endif()
endif()

# Create imported targets for requested components

# Component: zzaf (FLTK UI components)
if(NOT ZZAF_REQUESTED EQUAL -1 AND FLTK_FOUND AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzaf${CMAKE_STATIC_LIBRARY_SUFFIX}")
    if(NOT TARGET zzacommon::zzaf)
        add_library(zzacommon::zzaf STATIC IMPORTED)
        set(ZZAF_LIB "${PACKAGE_PREFIX_DIR}/lib/zzaf${CMAKE_STATIC_LIBRARY_SUFFIX}")
        set_target_properties(zzacommon::zzaf PROPERTIES
            IMPORTED_LOCATION "${ZZAF_LIB}"
            INTERFACE_INCLUDE_DIRECTORIES "${ZZACOMMON_INCLUDE_DIR};${FLTK_INCLUDE_DIR}"
            INTERFACE_LINK_LIBRARIES "${FLTK_LIBRARIES}"
        )

        # Add nlohmann/json include if on MSVC
        if(MSVC AND EXISTS "$ENV{USERPROFILE}/source/repos/json/include")
            set_property(TARGET zzacommon::zzaf APPEND PROPERTY
                INTERFACE_INCLUDE_DIRECTORIES "$ENV{USERPROFILE}/source/repos/json/include"
            )
        endif()

        list(APPEND ZZACOMMON_COMPONENTS zzaf)
        list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzaf)
        set(zzacommon_zzaf_FOUND TRUE)
    endif()
endif()

# Component: zzab (Boost components)
if(NOT ZZAB_REQUESTED EQUAL -1 AND Boost_FOUND AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzab${CMAKE_STATIC_LIBRARY_SUFFIX}")
    if(NOT TARGET zzacommon::zzab)
        add_library(zzacommon::zzab STATIC IMPORTED)
        set(ZZAB_LIB "${PACKAGE_PREFIX_DIR}/lib/zzab${CMAKE_STATIC_LIBRARY_SUFFIX}")
        if(MSVC)
            set(_ZZAB_BOOST_LIBS "Boost::filesystem;Boost::asio")
        else()
            set(_ZZAB_BOOST_LIBS "Boost::filesystem;Boost::headers")
        endif()
        set_target_properties(zzacommon::zzab PROPERTIES
            IMPORTED_LOCATION "${ZZAB_LIB}"
            INTERFACE_INCLUDE_DIRECTORIES "${ZZACOMMON_INCLUDE_DIR}"
            INTERFACE_LINK_LIBRARIES "${_ZZAB_BOOST_LIBS}"
            INTERFACE_COMPILE_DEFINITIONS "_WIN32_WINNT=0x0601"
        )

        list(APPEND ZZACOMMON_COMPONENTS zzab)
        list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzab)
        set(zzacommon_zzab_FOUND TRUE)

        # Export Boost DLL paths for user applications
        zzacommon_find_boost_dlls("${_ZZACOMMON_VCPKG_ROOT}")
    endif()
endif()

# Component: zzax (XML, URL handling, and FLTK)
if(NOT ZZAX_REQUESTED EQUAL -1 AND FLTK_FOUND AND CURL_FOUND AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzax${CMAKE_STATIC_LIBRARY_SUFFIX}")
    if(NOT TARGET zzacommon::zzax)
        add_library(zzacommon::zzax STATIC IMPORTED)
        set(ZZAX_LIB "${PACKAGE_PREFIX_DIR}/lib/zzax${CMAKE_STATIC_LIBRARY_SUFFIX}")

        # Build link libraries list
        set(ZZAX_LINK_LIBS "pugixml;CURL::libcurl;${FLTK_LIBRARIES}")
        if(MSVC AND TARGET ZLIB::ZLIB)
            list(APPEND ZZAX_LINK_LIBS ZLIB::ZLIB)
        endif()

        set_target_properties(zzacommon::zzax PROPERTIES
            IMPORTED_LOCATION "${ZZAX_LIB}"
            INTERFACE_INCLUDE_DIRECTORIES "${ZZACOMMON_INCLUDE_DIR};${PUGIXML_INCLUDE_DIR};${CURL_INCLUDE_DIRS};${FLTK_INCLUDE_DIR}"
            INTERFACE_LINK_LIBRARIES "${ZZAX_LINK_LIBS}"
        )

        list(APPEND ZZACOMMON_COMPONENTS zzax)
        list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzax)
        set(zzacommon_zzax_FOUND TRUE)

        # Export zlib DLL paths for user applications
        zzacommon_find_zlib_dlls("${_ZZACOMMON_VCPKG_ROOT}")
    endif()
endif()

# Component: zzam (Common utilities)
if(NOT ZZAM_REQUESTED EQUAL -1)
    # Find nlohmann_json (required for zzam)
    find_package(nlohmann_json CONFIG QUIET)

    if(NOT nlohmann_json_FOUND)
        # Fallback to hardcoded path check
        if(MSVC AND EXISTS "$ENV{USERPROFILE}/source/repos/json/include")
            set(NLOHMANN_JSON_INCLUDE_DIR "$ENV{USERPROFILE}/source/repos/json/include")
            message(STATUS "zzacommon: Using local nlohmann_json at ${NLOHMANN_JSON_INCLUDE_DIR}")
        else()
            # Try to find in system paths
            find_path(NLOHMANN_JSON_INCLUDE_DIR 
                NAMES nlohmann/json.hpp
                PATHS /usr/include /usr/local/include
            )
        endif()
    endif()

    if(NOT TARGET zzacommon::zzam AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzam${CMAKE_STATIC_LIBRARY_SUFFIX}")
        add_library(zzacommon::zzam STATIC IMPORTED)
        set(ZZAM_LIB "${PACKAGE_PREFIX_DIR}/lib/zzam${CMAKE_STATIC_LIBRARY_SUFFIX}")

        # Build interface link libraries
        set(ZZAM_LINK_LIBS "")
        if(TARGET nlohmann_json::nlohmann_json)
            set(ZZAM_LINK_LIBS "nlohmann_json::nlohmann_json")
        endif()

        set_target_properties(zzacommon::zzam PROPERTIES
            IMPORTED_LOCATION "${ZZAM_LIB}"
            INTERFACE_INCLUDE_DIRECTORIES "${ZZACOMMON_INCLUDE_DIR}"
        )

        # Add nlohmann_json include or target
        if(TARGET nlohmann_json::nlohmann_json)
            set_property(TARGET zzacommon::zzam APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES "nlohmann_json::nlohmann_json"
            )
            message(STATUS "zzacommon: zzam linked with nlohmann_json::nlohmann_json target")
        elseif(NLOHMANN_JSON_INCLUDE_DIR AND EXISTS "${NLOHMANN_JSON_INCLUDE_DIR}")
            set_property(TARGET zzacommon::zzam APPEND PROPERTY
                INTERFACE_INCLUDE_DIRECTORIES "${NLOHMANN_JSON_INCLUDE_DIR}"
            )
            message(STATUS "zzacommon: zzam using nlohmann_json include: ${NLOHMANN_JSON_INCLUDE_DIR}")
        else()
            message(WARNING "zzacommon: nlohmann_json not found for zzam component")
        endif()

        list(APPEND ZZACOMMON_COMPONENTS zzam)
        list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzam)
        set(zzacommon_zzam_FOUND TRUE)
    endif()
endif()

# Component: zzafb (FLTK + Boost components)
if(NOT ZZAFB_REQUESTED EQUAL -1 AND FLTK_FOUND AND Boost_FOUND)
    # Find nlohmann_json (required for zzafb since it includes zc_banner/zc_status which use zc_settings.h)
    if(NOT TARGET nlohmann_json::nlohmann_json AND NOT NLOHMANN_JSON_INCLUDE_DIR)
        find_package(nlohmann_json CONFIG QUIET)

        if(NOT nlohmann_json_FOUND)
            # Fallback to hardcoded path check
            if(MSVC AND EXISTS "$ENV{USERPROFILE}/source/repos/json/include")
                set(NLOHMANN_JSON_INCLUDE_DIR "$ENV{USERPROFILE}/source/repos/json/include")
                message(STATUS "zzacommon: Using local nlohmann_json at ${NLOHMANN_JSON_INCLUDE_DIR}")
            else()
                # Try to find in system paths
                find_path(NLOHMANN_JSON_INCLUDE_DIR 
                    NAMES nlohmann/json.hpp
                    PATHS /usr/include /usr/local/include
                )
            endif()
        endif()
    endif()

    if(NOT TARGET zzacommon::zzafb AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzafb${CMAKE_STATIC_LIBRARY_SUFFIX}")
        add_library(zzacommon::zzafb STATIC IMPORTED)
        set(ZZAFB_LIB "${PACKAGE_PREFIX_DIR}/lib/zzafb${CMAKE_STATIC_LIBRARY_SUFFIX}")

        # Build link libraries list
        if(MSVC)
            set(ZZAFB_LINK_LIBS "Boost::filesystem;Boost::asio;${FLTK_LIBRARIES}")
        else()
            set(ZZAFB_LINK_LIBS "Boost::filesystem;Boost::headers;${FLTK_LIBRARIES}")
        endif()

        set_target_properties(zzacommon::zzafb PROPERTIES
            IMPORTED_LOCATION "${ZZAFB_LIB}"
            INTERFACE_INCLUDE_DIRECTORIES "${ZZACOMMON_INCLUDE_DIR}"
            INTERFACE_LINK_LIBRARIES "${ZZAFB_LINK_LIBS}"
        )

        # Add nlohmann_json include or target
        if(TARGET nlohmann_json::nlohmann_json)
            set_property(TARGET zzacommon::zzafb APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES "nlohmann_json::nlohmann_json"
            )
            message(STATUS "zzacommon: zzafb linked with nlohmann_json::nlohmann_json target")
        elseif(NLOHMANN_JSON_INCLUDE_DIR AND EXISTS "${NLOHMANN_JSON_INCLUDE_DIR}")
            set_property(TARGET zzacommon::zzafb APPEND PROPERTY
                INTERFACE_INCLUDE_DIRECTORIES "${NLOHMANN_JSON_INCLUDE_DIR}"
            )
            message(STATUS "zzacommon: zzafb using nlohmann_json include: ${NLOHMANN_JSON_INCLUDE_DIR}")
        else()
            message(WARNING "zzacommon: nlohmann_json not found for zzafb component")
        endif()

        list(APPEND ZZACOMMON_COMPONENTS zzafb)
        list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzafb)
        set(zzacommon_zzafb_FOUND TRUE)

        # Export Boost DLL paths for user applications (if not already set by zzab)
        if(NOT ZZACOMMON_BOOST_DLLS_RELEASE)
            zzacommon_find_boost_dlls("${_ZZACOMMON_VCPKG_ROOT}")
        endif()
    endif()
endif()

# Component: zzad (Debug utilities - no external dependencies)
if(NOT ZZAD_REQUESTED EQUAL -1 AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzad${CMAKE_STATIC_LIBRARY_SUFFIX}")
    if(NOT TARGET zzacommon::zzad)
        add_library(zzacommon::zzad STATIC IMPORTED)
        set(ZZAD_LIB "${PACKAGE_PREFIX_DIR}/lib/zzad${CMAKE_STATIC_LIBRARY_SUFFIX}")
        set_target_properties(zzacommon::zzad PROPERTIES
            IMPORTED_LOCATION "${ZZAD_LIB}"
            INTERFACE_INCLUDE_DIRECTORIES "${ZZACOMMON_INCLUDE_DIR}"
        )

        list(APPEND ZZACOMMON_COMPONENTS zzad)
        list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzad)
        set(zzacommon_zzad_FOUND TRUE)
    endif()
endif()

# Component: zzap (PortAudio audio output)
if(NOT ZZAP_REQUESTED EQUAL -1)
    # zzap requires zzam component (for zc_settings)
    if(NOT TARGET zzacommon::zzam)
        message(WARNING "zzacommon: zzap component requires zzam component. Please request zzam along with zzap.")
        set(zzacommon_zzap_FOUND FALSE)
    else()
        # Find PortAudio - try multiple methods
        set(PORTAUDIO_FOUND_LOCAL FALSE)

        # Determine PORTAUDIO_ROOT from CMake variable or environment variable
        set(_PORTAUDIO_ROOT "")
        if(DEFINED PORTAUDIO_ROOT AND EXISTS "${PORTAUDIO_ROOT}")
            set(_PORTAUDIO_ROOT "${PORTAUDIO_ROOT}")
            message(STATUS "zzacommon: Using PORTAUDIO_ROOT CMake variable: ${_PORTAUDIO_ROOT}")
        elseif(DEFINED ENV{PORTAUDIO_ROOT} AND EXISTS "$ENV{PORTAUDIO_ROOT}")
            set(_PORTAUDIO_ROOT "$ENV{PORTAUDIO_ROOT}")
            message(STATUS "zzacommon: Using PORTAUDIO_ROOT environment variable: ${_PORTAUDIO_ROOT}")
        endif()

        # Method 1: Check if PORTAUDIO_ROOT is set (CMake variable or environment variable)
        if(_PORTAUDIO_ROOT)
            if(MSVC)
                # Check if PortAudio target already exists (from previous configuration or vcpkg)
                if(NOT TARGET portaudio_static AND NOT TARGET portaudio)
                    # Add PortAudio as subdirectory if source is available
                    # Use a unique binary directory to avoid conflicts between configurations
                    add_subdirectory(${_PORTAUDIO_ROOT}
                        ${CMAKE_CURRENT_BINARY_DIR}/zzacommon_portaudio
                        EXCLUDE_FROM_ALL
                    )
                    message(STATUS "zzacommon: Building PortAudio from source")
                elseif(TARGET portaudio_static)
                    message(STATUS "zzacommon: PortAudio target 'portaudio_static' already exists")
                elseif(TARGET portaudio)
                    message(STATUS "zzacommon: PortAudio target 'portaudio' already exists")
                endif()

                set(PORTAUDIO_FOUND_LOCAL TRUE)
                if(TARGET portaudio_static)
                    set(ZZAP_PORTAUDIO_LIB "portaudio_static")
                elseif(TARGET portaudio)
                    set(ZZAP_PORTAUDIO_LIB "portaudio")
                endif()
                set(PORTAUDIO_INCLUDE_DIR "${_PORTAUDIO_ROOT}/include")
                message(STATUS "zzacommon: Using PortAudio from PORTAUDIO_ROOT: ${_PORTAUDIO_ROOT}")
            else()
                find_library(PORTAUDIO_LIBRARIES
                    NAMES portaudio
                    HINTS "${_PORTAUDIO_ROOT}/lib" "${_PORTAUDIO_ROOT}/lib64" "/usr/local/lib" "/usr/lib" "/usr/lib64"
                )
                find_path(PORTAUDIO_INCLUDE_DIR
                    NAMES portaudio.h
                    HINTS "${_PORTAUDIO_ROOT}/include" "/usr/local/include" "/usr/include"
                )
                if(PORTAUDIO_LIBRARIES)
                    set(PORTAUDIO_FOUND_LOCAL TRUE)
                    message(STATUS "zzacommon: Using PortAudio library from PORTAUDIO_ROOT: ${_PORTAUDIO_ROOT}")
                endif()
            endif()
        endif()

        # Method 2: Try to find via vcpkg/system
        if(NOT PORTAUDIO_FOUND_LOCAL)
            if(MSVC)
                find_package(portaudio CONFIG QUIET)
                if(NOT portaudio_FOUND)
                    find_package(PortAudio MODULE QUIET)
                endif()

                if(portaudio_FOUND OR PORTAUDIO_FOUND OR PortAudio_FOUND)
                    set(PORTAUDIO_FOUND_LOCAL TRUE)
                endif()
            else()
                find_package(PkgConfig QUIET)
                if(PkgConfig_FOUND)
                    pkg_check_modules(PORTAUDIO QUIET portaudio-2.0)
                endif()

                if(PORTAUDIO_FOUND)
                    if(PORTAUDIO_INCLUDE_DIRS)
                        set(PORTAUDIO_INCLUDE_DIR ${PORTAUDIO_INCLUDE_DIRS})
                    endif()
                    if(PORTAUDIO_LINK_LIBRARIES)
                        set(PORTAUDIO_LIBRARIES ${PORTAUDIO_LINK_LIBRARIES})
                    elseif(PORTAUDIO_LIBRARIES)
                        set(PORTAUDIO_LIBRARIES ${PORTAUDIO_LIBRARIES})
                    endif()
                    set(PORTAUDIO_FOUND_LOCAL TRUE)
                    message(STATUS "zzacommon: PortAudio found via pkg-config (portaudio-2.0)")
                else()
                    find_library(PORTAUDIO_LIBRARIES
                        NAMES portaudio
                        PATHS /usr/local/lib /usr/lib /usr/lib64
                    )
                    find_path(PORTAUDIO_INCLUDE_DIR
                        NAMES portaudio.h
                        PATHS /usr/local/include /usr/include
                    )
                    if(PORTAUDIO_LIBRARIES)
                        set(PORTAUDIO_FOUND_LOCAL TRUE)
                        message(STATUS "zzacommon: PortAudio found via library search")
                    endif()
                endif()
            endif()
        endif()

        if(PORTAUDIO_FOUND_LOCAL)
            if(NOT TARGET zzacommon::zzap AND EXISTS "${PACKAGE_PREFIX_DIR}/lib/zzap${CMAKE_STATIC_LIBRARY_SUFFIX}")
                add_library(zzacommon::zzap STATIC IMPORTED)
                set(ZZAP_LIB "${PACKAGE_PREFIX_DIR}/lib/zzap${CMAKE_STATIC_LIBRARY_SUFFIX}")

                # Determine PortAudio link target and include directory
                set(ZZAP_INCLUDE_DIRS "${ZZACOMMON_INCLUDE_DIR}")
                if(TARGET portaudio)
                    set(ZZAP_PORTAUDIO_LIB "portaudio")
                    # Get include directories from target
                    get_target_property(PA_INCLUDES portaudio INTERFACE_INCLUDE_DIRECTORIES)
                    if(PA_INCLUDES)
                        list(APPEND ZZAP_INCLUDE_DIRS ${PA_INCLUDES})
                    endif()
                elseif(TARGET portaudio_static)
                    set(ZZAP_PORTAUDIO_LIB "portaudio_static")
                    # Get include directories from target
                    get_target_property(PA_INCLUDES portaudio_static INTERFACE_INCLUDE_DIRECTORIES)
                    if(PA_INCLUDES)
                        list(APPEND ZZAP_INCLUDE_DIRS ${PA_INCLUDES})
                    endif()
                elseif(PORTAUDIO_LIBRARIES)
                    set(ZZAP_PORTAUDIO_LIB "${PORTAUDIO_LIBRARIES}")
                    # Try to find PortAudio include directory
                    if(PORTAUDIO_INCLUDE_DIR AND EXISTS "${PORTAUDIO_INCLUDE_DIR}")
                        list(APPEND ZZAP_INCLUDE_DIRS "${PORTAUDIO_INCLUDE_DIR}")
                    elseif(PORTAUDIO_INCLUDE_DIRS AND EXISTS "${PORTAUDIO_INCLUDE_DIRS}")
                        list(APPEND ZZAP_INCLUDE_DIRS "${PORTAUDIO_INCLUDE_DIRS}")
                    endif()
                endif()

                # Build link libraries (PortAudio + zzam, optionally zzaf)
                set(ZZAP_LINK_LIBS "${ZZAP_PORTAUDIO_LIB};zzacommon::zzam")
                if(TARGET zzacommon::zzaf)
                    list(APPEND ZZAP_LINK_LIBS "zzacommon::zzaf")
                endif()

                set_target_properties(zzacommon::zzap PROPERTIES
                    IMPORTED_LOCATION "${ZZAP_LIB}"
                    INTERFACE_INCLUDE_DIRECTORIES "${ZZAP_INCLUDE_DIRS}"
                    INTERFACE_LINK_LIBRARIES "${ZZAP_LINK_LIBS}"
                )

                message(STATUS "zzacommon: zzap will use PortAudio includes: ${ZZAP_INCLUDE_DIRS}")
                list(APPEND ZZACOMMON_COMPONENTS zzap)
                list(APPEND ZZACOMMON_LIBRARIES zzacommon::zzap)
                set(zzacommon_zzap_FOUND TRUE)
            endif()
        else()
            if(MSVC)
                message(WARNING "zzacommon: PortAudio not found for zzap component. Please either:\n"
                    "  1. Set PORTAUDIO_ROOT environment variable to PortAudio source directory, OR\n"
                    "  2. Install PortAudio via vcpkg: vcpkg install portaudio:x64-windows")
            else()
                message(WARNING "zzacommon: PortAudio not found for zzap component on Linux. Please either:\n"
                    "  1. Install PortAudio development package (e.g. portaudio19-dev), OR\n"
                    "  2. Set PORTAUDIO_ROOT to your PortAudio installation prefix")
            endif()
            set(zzacommon_zzap_FOUND FALSE)
        endif()
    endif()
endif()

# Check if all required components were found
set(zzacommon_FOUND TRUE)
foreach(comp ${zzacommon_FIND_COMPONENTS})
    if(NOT zzacommon_${comp}_FOUND)
        if(zzacommon_FIND_REQUIRED_${comp})
            set(zzacommon_FOUND FALSE)
            set(zzacommon_NOT_FOUND_MESSAGE "Required component not found: ${comp}")
        endif()
    endif()
endforeach()

# Set standard find_package variables
if(zzacommon_FOUND)
    message(STATUS "Found zzacommon ${zzacommon_VERSION} with components: ${ZZACOMMON_COMPONENTS}")
    set(zzacommon_INCLUDE_DIRS ${ZZACOMMON_INCLUDE_DIR})
else()
    if(zzacommon_FIND_REQUIRED)
        message(FATAL_ERROR "${zzacommon_NOT_FOUND_MESSAGE}")
    endif()
endif()
